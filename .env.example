# ── LLM Configuration ─────────────────────────────────────────────────────────
# Option A: LM Studio (local, recommended — PII never leaves the device)
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=lmstudio-community/Meta-Llama-3.1-8B-Instruct-GGUF

# Option B: OpenAI API (swap by changing these three lines)
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# ── Embeddings ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── ChromaDB ───────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=lendflow_policy

# ── Pipeline ───────────────────────────────────────────────────────────────────
CONFIDENCE_HIGH_THRESHOLD=0.85
CONFIDENCE_LOW_THRESHOLD=0.65
MAX_POLICY_CHUNKS=5
MAX_RETRIES=2

# ── Audit ──────────────────────────────────────────────────────────────────────
AUDIT_LOG_DIR=./data/audit_logs

# ── LangSmith Observability (optional) ────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=lendflow

# ── FastAPI ────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
